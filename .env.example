NODE_ENV=development
PORT=2000

# Current bearer value. Requests can use: Authorization: Bearer <API_KEY>
API_KEY=change-me

# JWT tokens are signed with this. Use a long random value in production.
JWT_SECRET=change-me-jwt-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Username/password login. Prefer AUTH_PASSWORD_SHA256 in production.
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me-password
# AUTH_PASSWORD_SHA256=
AUTH_ROLE=admin
AUTH_COOKIE_NAME=access_token
AUTH_REFRESH_COOKIE_NAME=refresh_token

# Turso / libSQL
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# Comma-separated list, or * for all origins.
CORS_ORIGIN=*

# Generic /api/db/query allows only SELECT/WITH/PRAGMA by default.
ALLOW_WRITE_SQL=false
